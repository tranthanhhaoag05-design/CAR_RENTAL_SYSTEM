{
	"info": {
		"name": "CAR_RENTAL_API (Nhóm 03)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Đăng nhập (Lấy Token)",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\r\n    \"phone_number\": \"0987654321\",\r\n    \"password\": \"123456\"\r\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "http://127.0.0.1:8000/api/login",
					"protocol": "http",
					"host": ["127", "0", "0", "1"],
					"port": "8000",
					"path": ["api", "login"]
				}
			}
		},
		{
			"name": "2. Lấy Danh sách xe",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://127.0.0.1:8000/api/vehicles",
					"protocol": "http",
					"host": ["127", "0", "0", "1"],
					"port": "8000",
					"path": ["api", "vehicles"]
				}
			}
		},
		{
			"name": "3. Đặt xe (Gửi File Ảnh)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "DÁN_TOKEN_VÀO_ĐÂY",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [],
				"body": {
					"mode": "formdata",
					"formdata": [
						{ "key": "vehicle_id", "value": "1", "type": "text" },
						{ "key": "start_date", "value": "2026-05-01", "type": "text" },
						{ "key": "end_date", "value": "2026-05-05", "type": "text" },
						{ "key": "service_type", "value": "self_drive", "type": "text" },
						{ "key": "cccd_front", "type": "file" },
						{ "key": "cccd_back", "type": "file" },
						{ "key": "gplx", "type": "file" }
					]
				},
				"url": {
					"raw": "http://127.0.0.1:8000/api/bookings",
					"protocol": "http",
					"host": ["127", "0", "0", "1"],
					"port": "8000",
					"path": ["api", "bookings"]
				}
			}
		}
	]
}